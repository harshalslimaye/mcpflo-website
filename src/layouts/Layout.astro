---
import "../styles/home.css";
import ThemeScript from "../components/ThemeScript.astro";
import NavTools from "../components/NavTools.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
}
const { title = "MCPFlo — Test your MCP servers" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ThemeScript />
  </head>
  <body>
    <!-- ============ NAVBAR ============ -->
    <nav class="nav">
      <div class="wrap nav-inner">
        <a href="/" class="wordmark"><img src="/assets/logo.png" alt="" width="22" height="22" /><span>MCP<span class="flo">Flo</span></span></a>
        <div class="nav-right">
          <div class="nav-links">
            <a href="/#features">Features</a>
            <a href="/docs/getting-started/what-is-mcpflo">Docs</a>
            <a href="#">Changelog</a>
            <a href="#" class="dl">Download</a>
          </div>
          <NavTools />
        </div>
      </div>
    </nav>

    <slot />

    <!-- ============ FOOTER ============ -->
    <Footer />

    <script>
      import "../scripts/theme.ts";
    </script>
  </body>
</html>
