---
import Layout from "../layouts/Layout.astro";
import { builds, repo, version, releaseDate, releaseUrl, releasesIndexUrl } from "../lib/releases";

const platforms = [
  { ...builds.mac, icon: "apple" as const },
  { ...builds.windows, icon: "windows" as const },
];
---
<Layout title="MCPFlo — Download">
  <section class="dl-sec">
    <div class="wrap dl-wrap">
      <p class="crumb mono">download</p>
      <h1 class="title">Download MCPFlo</h1>
      <p class="lede">
        v{version} · released {releaseDate} · free, MIT licensed. See the
        {" "}<a href={releaseUrl} target="_blank" rel="noopener">release notes</a>
        {" "}or browse <a href={releasesIndexUrl} target="_blank" rel="noopener">all builds on GitHub</a>.
      </p>

      <div class="platforms" id="platforms">
        {platforms.map((p) => (
          <div class="platform-card" data-platform={p.id}>
            <div class="platform-head">
              {p.icon === "apple" ? (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.36 1.43c0 1.14-.42 2.15-1.25 3.02-.83.87-1.94 1.5-3.16 1.4-.13-1.11.42-2.27 1.22-3.09.83-.87 2.13-1.44 3.19-1.33ZM19.9 17.14c-.44 1.03-.65 1.49-1.22 2.4-.79 1.27-1.9 2.85-3.28 2.86-1.22.02-1.53-.8-3.19-.79-1.66 0-2 .77-3.22.76-1.38-.02-2.43-1.44-3.22-2.71-2.21-3.55-2.44-7.71-1.08-9.93.97-1.58 2.5-2.5 3.94-2.5 1.47 0 2.39.81 3.6.81 1.18 0 1.89-.81 3.59-.81 1.28 0 2.64.7 3.61 1.9-3.17 1.74-2.66 6.28.67 8.01Z"/></svg>
              ) : (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.5 10.4 4.5v7H3V5.5Zm0 13 7.4 1v-7H3v6Zm8.4-8.5H21V4l-9.6 1.3v5.7Zm0 8.7L21 20V12h-9.6v6.7Z"/></svg>
              )}
              <h2 class="platform-name mono">{p.name}</h2>
            </div>

            <a class="btn-download" href={p.primary.href}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"/></svg>
              {p.primary.label}
            </a>
            <p class="build-meta mono">{p.primary.size}</p>

            {"secondary" in p && p.secondary && (
              <p class="alt-arch">
                Different chip? <a href={p.secondary.href}>{p.secondary.label}</a> ({p.secondary.size})
              </p>
            )}
          </div>
        ))}
      </div>

      <div class="src">
        <h3 class="group-label mono">Build from source</h3>
        <p>MCPFlo is open source. Clone and run it yourself:</p>
        <pre class="mono"><code>git clone {repo}.git
cd mcpflo
npm install
npm run dev</code></pre>
        <p><a href={repo} target="_blank" rel="noopener">View the repository on GitHub →</a></p>
      </div>
    </div>
  </section>
</Layout>

<script>
  import "../scripts/os-download.ts";
</script>

<style>
  .dl-sec{padding:56px 0 80px;}
  .dl-wrap{max-width:760px;}
  .crumb{font-size:12px;color:var(--fg-faint);margin:0 0 10px;}
  .crumb::before{content:"$ ";color:var(--accent);}
  .title{font-size:30px;font-weight:700;letter-spacing:-0.02em;margin:0 0 18px;line-height:1.2;}
  .lede{color:var(--text-muted);font-size:15px;line-height:1.65;margin:0 0 40px;}
  .lede a{color:var(--accent);}
  .lede a:hover{text-decoration:underline;}

  .platforms{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin:0 0 48px;}
  .platform-card{position:relative;border:1px solid var(--border);border-radius:12px;padding:24px;background:var(--bg-surface);}
  .platform-card.is-recommended{border-color:var(--accent);order:-1;}
  .badge{position:absolute;top:-11px;left:24px;background:var(--accent);color:#fff;
    font-size:11px;font-weight:600;letter-spacing:0.02em;padding:3px 10px;border-radius:20px;}
  .platform-head{display:flex;align-items:center;gap:10px;margin:0 0 18px;}
  .platform-head svg{width:22px;height:22px;color:var(--text-primary);}
  .platform-name{font-size:16px;font-weight:600;margin:0;}

  .btn-download{display:flex;align-items:center;justify-content:center;gap:8px;
    width:100%;padding:12px 16px;border-radius:8px;background:var(--btn);
    color:#fff;font-family:var(--mono);font-size:14px;font-weight:600;
    box-shadow:var(--shadow);}
  .btn-download svg{width:16px;height:16px;}
  .btn-download:hover{filter:brightness(1.05);}
  .build-meta{font-size:12px;color:var(--fg-faint);text-align:center;margin:10px 0 0;}
  .alt-arch{font-size:13px;color:var(--text-muted);margin:14px 0 0;text-align:center;}
  .alt-arch a{color:var(--accent);}
  .alt-arch a:hover{text-decoration:underline;}

  .src{border-top:1px solid var(--border);padding-top:32px;}
  .group-label{font-size:12px;color:var(--fg-faint);letter-spacing:0.04em;text-transform:uppercase;margin:0 0 14px;}
  .src p{font-size:14.5px;color:var(--text-primary);line-height:1.7;margin:0 0 14px;}
  .src a{color:var(--accent);}
  .src a:hover{text-decoration:underline;}
  .src pre{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;
    padding:16px;font-size:13px;line-height:1.7;color:var(--text-primary);overflow-x:auto;margin:0 0 14px;}

  @media (max-width:700px){
    .platforms{grid-template-columns:1fr;}
  }
</style>
