---
const repo = "https://github.com/harshalslimaye/mcpflo";
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap foot-grid">
    <div class="foot-brand">
      <a href="/" class="wordmark"><img src="/assets/logo.png" alt="" width="22" height="22" /><span>MCP<span class="flo">Flo</span></span></a>
      <p class="foot-desc">Test your MCP servers — invoke tools, inspect resources, and render prompts directly, with no model in the loop.</p>
    </div>

    <div class="foot-col">
      <h4 class="foot-heading mono">Resources</h4>
      <a href="/docs/getting-started/what-is-mcpflo">Documentation</a>
      <a href={repo} target="_blank" rel="noopener">Github</a>
      <a href={`${repo}/issues`} target="_blank" rel="noopener">Help</a>
    </div>

    <div class="foot-col">
      <h4 class="foot-heading mono">Community</h4>
      <a href="https://x.com/mcpflo" target="_blank" rel="noopener">Twitter</a>
      <a href="https://www.reddit.com/r/mcpflo/" target="_blank" rel="noopener">Reddit</a>
    </div>

    <div class="foot-col">
      <h4 class="foot-heading mono">Legal</h4>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </div>
  </div>

  <div class="wrap foot-bottom mono">
    © {year} MCPFlo. All rights reserved.
  </div>
</footer>

<style>
  footer{border-top:1px solid var(--border);background:var(--bg-primary);}
  .wrap{max-width:1100px;margin:0 auto;padding:0 32px;}
  .foot-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:32px;padding:48px 0 32px;}
  .foot-brand{padding-right:24px;}
  .foot-desc{margin-top:12px;font-size:13.5px;line-height:1.7;color:var(--text-muted);max-width:32ch;}
  .foot-col{display:flex;flex-direction:column;gap:12px;}
  .foot-heading{font-size:12px;color:var(--fg-faint);letter-spacing:0.04em;text-transform:uppercase;margin:0 0 2px;}
  .foot-col a{font-size:13.5px;color:var(--text-muted);}
  .foot-col a:hover{color:var(--text-primary);}
  .foot-bottom{padding:20px 0;border-top:1px solid var(--border);font-size:12.5px;color:var(--fg-faint);}
  @media (max-width:860px){
    .foot-grid{grid-template-columns:1fr 1fr;gap:32px 24px;}
    .foot-brand{grid-column:1 / -1;padding-right:0;}
    .foot-desc{max-width:none;}
  }
</style>
